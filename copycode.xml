<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
	<name>PLG_SYSTEM_COPYCODE</name>
	<author>Brian Teeman</author>
	<creationDate>July 2026</creationDate>
	<copyright>Copyright (c) 2026 Brian Teeman. All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE.txt</license>
	<authorEmail>brian@teeman.net</authorEmail>
	<authorUrl>https://brian.teeman.net</authorUrl>
	<version>1.0.0</version>
	<description><![CDATA[PLG_SYSTEM_COPYCODE_XML_DESCRIPTION]]></description>
	<namespace path="src">Brian\Plugin\System\CopyCode</namespace>
	<updateservers>
		<server type="extension" priority="1" name="CopyCode Update Site">https://raw.githubusercontent.com/brianteeman/copycode/main/manifest.xml</server>
	</updateservers>
	<files>
        <folder plugin="copycode">services</folder>
        <folder>src</folder>
    </files>

    <languages>
        <language tag="en-GB">language/en-GB/plg_system_copycode.ini</language>
        <language tag="en-GB">language/en-GB/plg_system_copycode.sys.ini</language>
    </languages>

    <media destination="plg_system_copycode" folder="media">
        <folder>js</folder>
        <folder>css</folder>
    </media>

</extension>